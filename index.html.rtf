<body>\
    <div class="container">\
        <header>\
            <h1>\uc0\u55357 \u56382  PETPET GIF Generator \u55357 \u56382 </h1>\
            <p class="subtitle">Turn any image into an adorable petting animation!</p>\
        </header>\
\
        <main>\
            <div class="upload-section">\
                <div class="upload-box" id="dropZone">\
                    <div class="upload-icon">\uc0\u55357 \u56548 </div>\
                    <p>Drag & drop an image here</p>\
                    <p class="or-text">- or -</p>\
                    <label for="fileInput" class="upload-btn">Choose File</label>\
