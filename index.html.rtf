    <script>\
        // DOM Elements\
        const dropZone = document.getElementById('dropZone');\
        const fileInput = document.getElementById('fileInput');\
        const fileName = document.getElementById('fileName');\
        const originalImage = document.getElementById('originalImage');\
        const originalContainer = document.getElementById('originalContainer');\
        const outputImage = document.getElementById('outputImage');\
        const outputContainer = document.getElementById('outputContainer');\
        const generateBtn = document.getElementById('generateBtn');\
        const downloadBtn = document.getElementById('downloadBtn');\
        const errorMessage = document.getElementById('errorMessage');\
        const errorText = document.querySelector('.error-text');\
\
        let selectedFile = null;\
        let generatedGifUrl = null;\
\
        // PetPet GIF Generation Function (Client-side simulation)\
        function generatePetPetGif(imageFile) \{\
            return new Promise((resolve, reject) => \{\
                const reader = new FileReader();\
                \
                reader.onload = (e) => \{\
                    const img = new Image();\
                    img.onload = () => \{\
                        // Create canvas for image processing\
                        const canvas = document.createElement('canvas');\
                        const ctx = canvas.getContext('2d');\
                        \
                        // Set canvas size to match image\
                        canvas.width = img.width;\
                        canvas.height = img.height;\
                        \
                        // Draw original image\
                        ctx.drawImage(img, 0, 0);\
                        \
                        // Create a simple animation effect (simulating petpet)\
                        // This creates a simple bouncing/patting effect\
                        const frames = [];\
                        const numFrames = 10;\
                        \
                        for (let i = 0; i < numFrames; i++) \{\
                            const frameCanvas = document.createElement('canvas');\
                            frameCanvas.width = img.width;\
                            frameCanvas.height = img.height;\
                            const frameCtx = frameCanvas.getContext('2d');\
                            \
                            // Calculate transformation for this frame\
                            const scale = 1 + (Math.sin(i / numFrames * Math.PI * 2) * 0.1);\
                            const xOffset = Math.sin(i / numFrames * Math.PI * 2) * 5;\
                            const yOffset = Math.cos(i / numFrames * Math.PI * 2) * 5;\
                            \
                            // Clear frame\
                            frameCtx.clearRect(0, 0, frameCanvas.width, frameCanvas.height);\
                            \
                            // Draw image with transformation\
                            frameCtx.save();\
                            frameCtx.translate(frameCanvas.width / 2 + xOffset, frameCanvas.height / 2 + yOffset);\
                            frameCtx.scale(scale, scale);\
                            frameCtx.drawImage(img, -img.width / 2, -img.height / 2);\
                            frameCtx.restore();\
                            \
                            frames.push(frameCanvas);\
                        \}\
                        \
                        // Combine frames into GIF using gif.js (we'll use a simpler approach)\
                        // For demonstration, we'll create an animated GIF using multiple frames\
                        const gif = new GIF(\{\
                            workers: 2,\
                            quality: 10,\
                            width: img.width,\
                            height: img.height\
                        \});\
                        \
                        // Add frames\
                        frames.forEach(frame => \{\
                            gif.addFrame(frame, \{delay: 100\});\
                        \});\
                        \
                        gif.on('finished', (blob) => \{\
                            const url = URL.createObjectURL(blob);\
                            resolve(url);\
                        \});\
                        \
                        gif.render();\
                    \};\
                    img.src = e.target.result;\
                \};\
                \
                reader.onerror = reject;\
                reader.readAsDataURL(imageFile);\
            \});\
        \}\
\
        // Load gif.js library dynamically\
        function loadGifJs() \{\
            return new Promise((resolve, reject) => \{\
                if (window.GIF) \{\
                    resolve();\
                    return;\
                \}\
                \
                const script = document.createElement('script');\
                script.src = 'https://cdn.jsdelivr.net/npm/gif.js@0.2.0/dist/gif.js';\
                script.onload = resolve;\
                script.onerror = reject;\
                document.head.appendChild(script);\
            \});\
        \}\
\
        // Drag and drop handlers\
        dropZone.addEventListener('dragover', (e) => \{\
            e.preventDefault();\
            dropZone.classList.add('drag-over');\
        \});\
\
        dropZone.addEventListener('dragleave', () => \{\
            dropZone.classList.remove('drag-over');\
        \});\
\
        dropZone.addEventListener('drop', (e) => \{\
            e.preventDefault();\
            dropZone.classList.remove('drag-over');\
            const files = e.dataTransfer.files;\
            if (files.length > 0) \{\
                handleFile(files[0]);\
            \}\
        \});\
\
        // File input handler\
        fileInput.addEventListener('change', (e) => \{\
            if (e.target.files.length > 0) \{\
                handleFile(e.target.files[0]);\
            \}\
        \});\
\
        function handleFile(file) \{\
            if (!file.type.startsWith('image/')) \{\
                showError('Please select an image file (PNG, JPG, GIF, or WebP)');\
                return;\
            \}\
\
            selectedFile = file;\
            fileName.textContent = file.name;\
\
            // Show preview\
            const reader = new FileReader();\
            reader.onload = (e) => \{\
                originalImage.src = e.target.result;\
                originalImage.style.display = 'block';\
                originalContainer.querySelector('.placeholder').style.display = 'none';\
                generateBtn.disabled = false;\
            \};\
            reader.readAsDataURL(file);\
\
            // Reset output\
            outputImage.src = '';\
            outputImage.style.display = 'none';\
            outputContainer.querySelector('.placeholder').style.display = 'block';\
            downloadBtn.style.display = 'none';\
            hideError();\
            \
            // Clean up old URL if exists\
            if (generatedGifUrl) \{\
                URL.revokeObjectURL(generatedGifUrl);\
                generatedGifUrl = null;\
            \}\
        \}\
\
        // Generate button handler\
        generateBtn.addEventListener('click', async () => \{\
            if (!selectedFile) return;\
\
            generateBtn.disabled = true;\
            generateBtn.textContent = 'Generating...';\
            hideError();\
\
            try \{\
                // Load gif.js if not already loaded\
                await loadGifJs();\
                \
                // Generate GIF\
                const gifUrl = await generatePetPetGif(selectedFile);\
                \
                // Display the generated GIF\
                outputImage.src = gifUrl;\
                outputImage.style.display = 'block';\
                outputContainer.querySelector('.placeholder').style.display = 'none';\
                downloadBtn.style.display = 'inline-block';\
                \
                // Store URL for download\
                generatedGifUrl = gifUrl;\
                \
                // Set up download\
                downloadBtn.onclick = () => \{\
                    const link = document.createElement('a');\
                    link.href = gifUrl;\
                    link.download = 'petpet.gif';\
                    link.click();\
                \};\
                \
            \} catch (error) \{\
                showError('Failed to generate GIF. Please try again.');\
                console.error('Generation error:', error);\
            \} finally \{\
                generateBtn.disabled = false;\
                generateBtn.textContent = 'Generate PetPet GIF';\
            \}\
        \});\
\
        function showError(message) \{\
            errorMessage.style.display = 'flex';\
            errorText.textContent = message;\
        \}\
\
        function hideError() \{\
            errorMessage.style.display = 'none';\
        \}\
\
        // Clean up on page unload\
        window.addEventListener('beforeunload', () => \{\
            if (generatedGifUrl) \{\
                URL.revokeObjectURL(generatedGifUrl);\
            \}\
        \});\
    </script>\
    \
    <!-- Add gif.js library -->\
    <script src="https://cdn.jsdelivr.net/npm/gif.js@0.2.0/dist/gif.js"></script>\
</body>\
</html>}